# RallyRank — local secrets template.
# Copy to `.env` and fill in real values. `.env` is gitignored.
#
# Usage: cp .env.example .env   then edit .env

# VLTC member portal (myaccount.aspx) — only needed if a future scrape requires
# authenticated endpoints. The current public-tournament scrape does NOT need this.
VLTC_USERNAME=
VLTC_PASSWORD=
